---
interface Props {
  className?: string;
}

import SectionLayout from "../../layouts/SectionLayout.astro";
import { Image } from "astro:assets";
import { cn } from "../../utils/cn";

// GeckoTerminal logo (oficial do kit CoinGecko)
import geckoIcon from "../../assets/icons/social/geckoterminal.png";

const { className } = Astro.props as Props;
const containerClass = cn(
  "flex flex-wrap items-center justify-center gap-x-6 gap-y-4",
  "py-4",
  className,
);
---

<SectionLayout>
  <div class={containerClass}>
    <div class="flex items-center gap-3 opacity-100">
      <Image
        src={geckoIcon}
        alt="GeckoTerminal"
        class="h-10 w-auto object-contain"
      />
    </div>
  </div>
</SectionLayout>
