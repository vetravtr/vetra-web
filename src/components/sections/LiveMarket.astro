---
interface Props {
  className?: string;
}

import SectionLayout from "../../layouts/SectionLayout.astro";
import AlignmentLayout from "../../layouts/AlignmentLayout.astro";
import Title from "../Title.astro";
import Badge from "../Badge.astro";
import { Image } from "astro:assets";
import { cn } from "../../utils/cn";
import Tooltip from "../common/Tooltip.astro";

import StarsIcon from "../../assets/icons/stars-light-sparkle.svg";
import geckoIcon from "../../assets/icons/social/geckoterminal.png";
import kucoinIcon from "../../assets/icons/social/kucoin-green.svg";
import logoVetra from "../../assets/logo.svg";

const sectionClasses = cn("py-16 md:py-24 mt-20");
const headerClasses = cn("max-w-[656px] text-center mx-auto mb-14");

const { className } = Astro.props as Props;

// Dados da GeckoTerminal API
const GT_API = "https://api.geckoterminal.com/api/v2/networks/polygon_pos/tokens/0xAA27bd271B01dd20CcFA079800616335416c95Fd/pools";
const GT_URL = "https://www.geckoterminal.com/polygon_pos/pools/0x98Bd9D327b6a3135A58eD6724d1b6170e683eeFa";
---

<SectionLayout className={cn(sectionClasses, className)}>
  <AlignmentLayout direction="vertical" justify="center" align="center" className="w-full">
    
    <!-- Header -->
    <div class={headerClasses}>
      <Badge text="Live Market" class="mb-4">
        <Image src={StarsIcon} alt="Sparkles" class="w-full h-full object-contain" width={12} height={12} />
      </Badge>
      <Title className="text-center mb-3 text-[24px] md:text-[32px] inline-flex items-center justify-center gap-3">
        <Image src={logoVetra} alt="VTR" class="h-8 w-auto inline" />
        <span>VTR price in real time</span>
      </Title>
    </div>

    <h2 class="sr-only">Live Market Data</h2>

    <!-- Ticker Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 w-full max-w-[1100px] mx-auto mb-8">
      
      <!-- Price -->
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5 text-center">
        <p class="text-text-grey text-xs uppercase tracking-wider mb-1">Price (USD)</p>
        <p id="gt-price" class="text-2xl font-medium text-white">—</p>
      </div>

      <!-- 24h Change -->
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5 text-center">
        <p class="text-text-grey text-xs uppercase tracking-wider mb-1">24h Change</p>
        <p id="gt-change" class="text-2xl font-medium text-white">—</p>
      </div>

      <!-- Liquidity -->
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5 text-center">
        <p class="text-text-grey text-xs uppercase tracking-wider mb-1">Liquidity (USD)</p>
        <p id="gt-liquidity" class="text-2xl font-medium text-white">—</p>
      </div>

      <!-- 24h Volume -->
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5 text-center">
        <p class="text-text-grey text-xs uppercase tracking-wider mb-1">24h Volume</p>
        <p id="gt-volume" class="text-2xl font-medium text-white">—</p>
      </div>

      <!-- FDV -->
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-5 text-center">
        <p class="text-text-grey text-xs uppercase tracking-wider mb-1">FDV (USD)</p>
        <p id="gt-fdv" class="text-2xl font-medium text-white">—</p>
      </div>
    </div>

    <!-- View on GeckoTerminal -->
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <a
        href={GT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/[0.12] text-sm font-medium text-white hover:bg-white/[0.05] transition-colors"
      >
        <Image src={geckoIcon} alt="" class="h-4 w-auto" />
        View on GeckoTerminal
      </a>

      <span class="text-white/20 hidden sm:inline">|</span>

      <a
        href="https://www.kucoin.com/r/broker/CXEMTGL5"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/[0.12] text-sm font-medium text-white hover:bg-white/[0.05] transition-colors"
      >
        <Image src={kucoinIcon} alt="" class="h-4 w-auto" />
        Buy on KuCoin
      </a>

      <span class="text-white/20 hidden sm:inline">|</span>

      <Tooltip content="0xAA27bd271B01dd20CcFA079800616335416c95Fd" label="Click to copy" position="top">
        <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/[0.12] text-sm font-mono text-text-grey hover:text-white hover:border-white/30 transition-all cursor-pointer">
          0xAA27...95Fd
        </span>
      </Tooltip>
    </div>

  </AlignmentLayout>
</SectionLayout>

<script>
  (function() {
    const API = "https://api.geckoterminal.com/api/v2/networks/polygon_pos/tokens/0xAA27bd271B01dd20CcFA079800616335416c95Fd/pools";
    
    async function fetchData() {
      try {
        const res = await fetch(API);
        const data = await res.json();
        const pools = data.data;
        
        if (!pools || pools.length === 0) return;

        // Pegar a primeira pool (principal) - GeckoTerminal ordena por relevância
        const mainPool = pools[0].attributes;
        
        const priceEl = document.getElementById("gt-price");
        if (priceEl && mainPool.base_token_price_usd) {
          priceEl.textContent = "$" + parseFloat(mainPool.base_token_price_usd).toFixed(6);
        }

        const changeEl = document.getElementById("gt-change");
        if (changeEl && mainPool.price_change_percentage?.h24 != null) {
          const val = parseFloat(mainPool.price_change_percentage.h24);
          changeEl.textContent = (val >= 0 ? "+" : "") + val.toFixed(2) + "%";
          changeEl.style.color = val >= 0 ? "#22c55e" : "#ef4444";
        }

        const liqEl = document.getElementById("gt-liquidity");
        if (liqEl && mainPool.reserve_in_usd) {
          const liq = parseFloat(mainPool.reserve_in_usd);
          if (liq >= 1000) {
            liqEl.textContent = "$" + (liq / 1000).toFixed(1) + "K";
          } else {
            liqEl.textContent = "$" + liq.toFixed(0);
          }
        }

        const volEl = document.getElementById("gt-volume");
        if (volEl && mainPool.volume_usd?.h24) {
          const vol = parseFloat(mainPool.volume_usd.h24);
          if (vol >= 1000) {
            volEl.textContent = "$" + (vol / 1000).toFixed(1) + "K";
          } else {
            volEl.textContent = "$" + vol.toFixed(0);
          }
        }

        // FDV = price * 30M
        const fdvEl = document.getElementById("gt-fdv");
        if (fdvEl && mainPool.base_token_price_usd) {
          const fdv = parseFloat(mainPool.base_token_price_usd) * 30_000_000;
          if (fdv >= 1_000_000) {
            fdvEl.textContent = "$" + (fdv / 1_000_000).toFixed(2) + "M";
          } else {
            fdvEl.textContent = "$" + fdv.toLocaleString(undefined, {maximumFractionDigits: 0});
          }
        }

      } catch (e) {
        console.log("GeckoTerminal data unavailable", e);
      }
    }

    fetchData();
  })();
</script>
