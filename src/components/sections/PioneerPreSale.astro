---
interface Props {
  className?: string;
}

import SectionLayout from "../../layouts/SectionLayout.astro";
import AlignmentLayout from "../../layouts/AlignmentLayout.astro";
import Badge from "../Badge.astro";
import Title from "../Title.astro";
import Description from "../Description.astro";
import { Image } from "astro:assets";
import { cn } from "../../utils/cn";

import StarsIcon from "../../assets/icons/stars-light-sparkle.svg";
import WalletConnect from "../WalletConnect.jsx";
import WalletConnectReferral from "../WalletConnectReferral.jsx";

const { className } = Astro.props as Props;
---

<section class={cn("py-16 md:py-24 relative", className)}>
  <div class="max-w-[1216px] mx-auto px-4">
    <div class="text-center mb-14">
      <Badge text="NFT Pre-Sale">
        <Image src={StarsIcon} alt="" class="w-full h-full object-contain" width={12} height={12} />
      </Badge>
      <Title className="text-center mt-4 text-[24px] md:text-[32px]">Be one of the pioneers to acquire VTR</Title>
      <Description text="Buy the NFT today, exchange for 1 VTR when the price reaches $0.40" className="text-center mt-2" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 flex flex-col gap-6">
        <div class="text-center">
          <p class="text-text-grey text-sm uppercase tracking-wider mb-1">Original Price</p>
          <p class="text-text-grey line-through text-xl">$0.40 USDC</p>
          <p class="text-light-purple text-4xl font-bold mt-1">$0.34 USDC</p>
          <span class="inline-block mt-1 bg-badge-purple/20 text-badge-purple text-xs font-semibold px-3 py-1 rounded-full">15% OFF</span>
        </div>
        <div>
          <div class="flex justify-between text-xs text-text-grey mb-1">
            <span>Current price: <span id="pioneer-current-price">$0.20</span></span>
            <span>Target: $0.40</span>
          </div>
          <div class="w-full h-3 bg-white/[0.06] rounded-full overflow-hidden">
            <div id="pioneer-progress-bar" class="h-full bg-gradient-to-r from-badge-purple to-light-purple rounded-full transition-all duration-500" style="width: 50%"></div>
          </div>
        </div>
        <WalletConnect client:only="react" />
        <div class="flex items-center justify-between bg-white/[0.03] border border-white/[0.06] rounded-xl px-4 py-3">
          <span class="text-text-grey text-sm font-mono">0xAA27...95Fd</span>
          <button data-copy="0xAA27bd271B01dd20CcFA079800616335416c95Fd" class="text-badge-purple hover:text-light-purple text-sm font-medium">COPY</button>
        </div>
        <div class="bg-badge-purple/5 border border-badge-purple/10 rounded-xl p-4">
          <p class="text-text-grey text-sm leading-relaxed"><strong class="text-white">1 NFT = 1 VTR</strong> at redemption. When the market price reaches $0.40, come back and exchange your NFT for 1 VTR.</p>
        </div>
      </div>
      <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 flex flex-col gap-6">
        <div class="text-center">
          <p class="text-2xl font-semibold text-white">Invite friends, earn more</p>
          <p class="text-text-grey text-sm mt-1">Each friend who buys = <strong class="text-light-purple">+5% VTR bonus</strong> on redemption day</p>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3"><span class="text-light-purple text-lg leading-none mt-0.5">1</span><p class="text-text-grey text-sm">Share your referral link with friends</p></div>
          <div class="flex items-start gap-3"><span class="text-light-purple text-lg leading-none mt-0.5">2</span><p class="text-text-grey text-sm">They buy an NFT — you get <strong class="text-white">+5% VTR</strong></p></div>
          <div class="flex items-start gap-3"><span class="text-light-purple text-lg leading-none mt-0.5">3</span><p class="text-text-grey text-sm">Bonus accumulates. Claim on redemption day</p></div>
          <div class="flex items-start gap-3"><span class="text-light-purple text-lg leading-none mt-0.5">4</span><p class="text-text-grey text-sm">No limits — refer as many as you want</p></div>
        </div>
        <WalletConnectReferral client:only="react" />
      </div>
    </div>
  </div>
</section>
