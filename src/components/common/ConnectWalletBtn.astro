---
---

<div class="w-full">
  <button
    id="ref-connect-btn"
    class="w-full py-3 rounded-full border border-white/[0.12] text-white font-medium text-sm hover:bg-white/[0.05] transition-all duration-300 flex items-center justify-center gap-2"
  >
    Connect Wallet
  </button>
</div>

<script>
  (function() {
    const btn = document.getElementById("ref-connect-btn");
    if (!btn) return;

    btn.addEventListener("click", async () => {
      // Verificar se há wallet injetada (MetaMask, Trust, Coinbase, Rabby, etc)
      if (typeof window.ethereum !== 'undefined') {
        try {
          const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
          const wallet = accounts[0];
          btn.textContent = "✅ " + wallet.slice(0,6) + "..." + wallet.slice(-4);
          btn.disabled = true;

          // Mostrar link referral
          const linkArea = document.getElementById("ref-link-area");
          const linkEl = document.getElementById("ref-link");
          if (linkArea && linkEl) {
            linkArea.classList.remove("hidden");
            linkEl.textContent = "vetravtr.com/r/" + wallet;
          }
        } catch (e) {
          console.error("User rejected connection", e);
        }
      } else {
        // Se não tem wallet injetada, sugerir instalar
        if (confirm('No wallet detected. Would you like to install MetaMask?')) {
          window.open('https://metamask.io', '_blank');
        }
      }
    });
  })();
</script>
