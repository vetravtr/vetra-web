---
import Layout from "../layouts/Layout.astro";
import GenericHeader from "../components/common/GenericHeader.astro";
import Hero from "../components/sections/Hero.astro";
import MostTrusted from "../components/sections/MostTrusted.astro";
import LiveMarket from "../components/sections/LiveMarket.astro";
import PioneerPreSale from "../components/sections/PioneerPreSale.astro";
import WhyChooseVetra from "../components/sections/WhyChooseVetra.astro";
import RealTimeReserves from "../components/sections/RealTimeReserves.astro";
import Newsletter from "../components/sections/Newsletter.astro";
import FAQ from "../components/sections/FAQ.astro";
import Footer from "../components/sections/Footer.astro";
import "../styles/global.css";
---

<Layout
  title="Vetra VTR"
  description="Built for real user. Crafted for low-cost transfers, instant finality, and audit-ready transparency making digital value dependable."
>
  {/* Structured Data (JSON-LD) */}
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Vetra",
          "description":
            "Built for real user. Crafted for low-cost transfers, instant finality, and audit-ready transparency making digital value dependable.",
          "url": "https://www.vetravtr.com/",
          "logo": "https://www.vetravtr.com/favicon.svg",
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "Customer Service",
            "availableLanguage": "English",
          },
          "areaServed": {
            "@type": "World",
            "name": "Global",
          },
          "knowsAbout": ["Stablecoin", "Cryptocurrency", "Payments", "Fintech"],
        },
        {
          "@type": "Product",
          "name": "VETRA (VTR)",
          "description": "A fully collateralized stablecoin backed by $100M USD reserves, deployed on Polygon Mainnet with Chainlink Proof-of-Reserves.",
          "category": "Cryptocurrency",
          "brand": {
            "@type": "Brand",
            "name": "Vetra"
          },
          "offers": {
            "@type": "AggregateOffer",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock"
          }
        }
      ]
    })}
  />
  <GenericHeader />

  <div class="relative z-10">
    <main>
      <Hero />
      <MostTrusted />
      <LiveMarket />
      <PioneerPreSale />
      <WhyChooseVetra />
      <RealTimeReserves />
      <Newsletter />
      <FAQ />
    </main>
    <Footer />
  </div>
</Layout>
