---
import Layout from "../../layouts/Layout.astro";
import GenericHeader from "../../components/common/GenericHeader.astro";
import Footer from "../../components/sections/Footer.astro";
import "../../styles/global.css";
---

<style>
  .construction {
    max-width: 600px;
    margin: 0 auto;
    padding: 160px 24px 120px;
    text-align: center;
    color: #fff;
    min-height: 60vh;
  }
  .construction h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    font-family: 'Urbanist', sans-serif;
  }
  .construction p {
    color: #9B9B9B;
    font-size: 1.1rem;
    font-family: 'Libre Franklin', sans-serif;
    line-height: 1.6;
  }
</style>

<Layout title="VETRA Blog — Coming Soon">
  <div class="relative">
    <GenericHeader />
    <main>
      <div class="construction">
        <h1>Blog</h1>
        <p>We're working on something great. Our blog is under construction and will launch soon with project history, educational content, promotions, launches, and partnership announcements.</p>
        <p style="margin-top: 24px; color: #b388ff;">Stay tuned.</p>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
