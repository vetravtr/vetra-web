---
import Layout from "../../layouts/Layout.astro";
import GenericHeader from "../../components/common/GenericHeader.astro";
import Footer from "../../components/sections/Footer.astro";
import { createClient } from "@supabase/supabase-js";
import { Image } from "astro:assets";

// Import all category images
import imgHistory from "../../assets/images/blog/categories/01_history.png";
import imgEducational from "../../assets/images/blog/categories/02_educational.png";
import imgPromotions from "../../assets/images/blog/categories/03_promotions.png";
import imgLaunches from "../../assets/images/blog/categories/04_launches.png";
import imgPartnerships from "../../assets/images/blog/categories/05_partnerships.png";
import imgSecurity from "../../assets/images/blog/categories/06_security_and_compliance.png";
import imgMarketInsights from "../../assets/images/blog/categories/07_market_insights.png";
import imgTechDev from "../../assets/images/blog/categories/08_tech_and_development.png";
import imgCommunity from "../../assets/images/blog/categories/09_community_and_governance.png";
import imgUseCases from "../../assets/images/blog/categories/10_use_cases.png";

import "../../styles/global.css";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let posts = [];
let error = null;

if (supabaseUrl && supabaseKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data } = await supabase.from("blog_posts").select("*").order("created_at", { ascending: false });
    if (data) posts = data;
  } catch (e) {
    error = e.message;
  }
}

const catNames = {
  history: "History", educational: "Educational", promotions: "Promotions",
  launches: "Launches", partnerships: "Partnerships", kucoin: "KuCoin",
  "security-compliance": "Security", "market-insights": "Markets",
  "tech-dev": "Tech", community: "Community", "use-cases": "Use Cases"
};

// Map categ slug -> image file
const catImages: Record<string, string> = {
  history: "01_history.png",
  educational: "02_educational.png",
  promotions: "03_promotions.png",
  launches: "04_launches.png",
  partnerships: "05_partnerships.png",
  "security-compliance": "06_security_and_compliance.png",
  "market-insights": "07_market_insights.png",
  "tech-dev": "08_tech_and_development.png",
  community: "09_community_and_governance.png",
  "use-cases": "10_use_cases.png",
};

// Map categ slug -> image import
const catImgImport: Record<string, any> = {
  history: imgHistory,
  educational: imgEducational,
  promotions: imgPromotions,
  launches: imgLaunches,
  partnerships: imgPartnerships,
  "security-compliance": imgSecurity,
  "market-insights": imgMarketInsights,
  "tech-dev": imgTechDev,
  community: imgCommunity,
  "use-cases": imgUseCases,
};

const catDescriptions: Record<string, string> = {
  history: "The story behind VETRA \u2014 from concept to a fully collateralized stablecoin.",
  educational: "Learn about stablecoins, DeFi, blockchain, and how VETRA works.",
  promotions: "Campaigns, referral programs, and special offers for the VETRA community.",
  launches: "New product launches, token milestones, and ecosystem expansions.",
  partnerships: "Strategic collaborations and integrations across the crypto space.",
  "security-compliance": "Audits, proof-of-reserves, regulatory compliance, and security practices.",
  "market-insights": "Market analysis, price trends, and on-chain data breakdowns.",
  "tech-dev": "Technical deep dives into VETRA\u2019s smart contracts, infrastructure, and upgrades.",
  community: "Community news, events, governance proposals, and ambassador programs.",
  "use-cases": "Real-world applications of VETRA: payments, settlements, treasury management."
};

const catList = [...new Set(posts.filter(p => p.category).map(p => p.category))].sort();
const activeCat = Astro.url.searchParams.get("category");
const filtered = activeCat ? posts.filter(p => p.category === activeCat) : posts;
---

<style>
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    color: #fff;
    min-height: 80vh;
  }
  .blog-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    font-family: 'Urbanist', sans-serif;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }
  .blog-header p {
    color: #a0aec0;
    font-size: 0.95rem;
    font-family: 'Libre Franklin', sans-serif;
    margin-bottom: 32px;
  }
  
  .category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
  margin-bottom: 0;
}

.cat-block {
  background: rgba(100, 51, 144, 0.08);
  border: 1px solid rgba(100, 51, 144, 0.25);
  border-radius: 12px;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(4px);
}
.cat-block:hover {
  border-color: rgba(100, 51, 144, 0.8);
  background: rgba(100, 51, 144, 0.15);
  transform: translateY(-2px);
}
.cat-block-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.cat-block-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.cat-block-title {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  font-family: 'Urbanist', sans-serif;
}
.cat-block-desc {
  font-size: 0.8rem;
  color: #a0aec0;
  line-height: 1.5;
  font-family: 'Libre Franklin', sans-serif;
}
.cat-block-count {
  font-size: 0.7rem;
  color: #b388ff;
  font-weight: 600;
  font-family: 'Urbanist', sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-top: 4px;
}

/* Quando filtrando por categoria, posts-grid ocupa tudo */
.blog-layout:has(.sidebar-box) .posts-grid {
  grid-column: 1;
}
.blog-layout:not(:has(.sidebar-box)) .posts-grid {
  grid-column: 1 / -1;
}

 @media (max-width: 1024px) {
    .category-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .blog-header h1 { font-size: 2rem; }
    .category-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<Layout title="VETRA Blog">
  <div class="relative">
    <GenericHeader />
    <main>
      <div class="blog-container">
        <div class="blog-header">
          <h1>Blog</h1>
          <p>VETRA News, educational, content, and updates</p>
        </div>
        
        <!-- Category blocks with images -->
        <div class="category-grid">
          {catList.map((cat) => {
            const imgFile = catImages[cat];
            const label = catNames[cat] || cat;
            const desc = catDescriptions[cat] || '';
            const count = posts.filter(p => p.category === cat).length;
            return (
              <a href={`/blog/category/${cat}`} class="cat-block">
                {imgFile && (
                  <Image
                    src={catImgImport[cat]}
                    alt={label}
                    class="cat-block-img"
                    loading="lazy"
                  />
                )}
                <div class="cat-block-body">
                  <div class="cat-block-title">{label}</div>
                  <div class="cat-block-desc">{desc}</div>
                  <div class="cat-block-count">{count} {count === 1 ? 'post' : 'posts'}</div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // placeholder para futura funcionalidade
});
</script>
