---
import Layout from "../../layouts/Layout.astro";
import GenericHeader from "../../components/common/GenericHeader.astro";
import Footer from "../../components/sections/Footer.astro";
import "../../styles/global.css";
import { createClient } from "@supabase/supabase-js";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let posts = [];
let error = null;

if (supabaseUrl && supabaseKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data } = await supabase.from("blog_posts").select("*").order("created_at", { ascending: false });
    if (data) posts = data;
  } catch (e) {
    error = e.message;
  }
}

const catNames = {
  history: "History", educational: "Educational", promotions: "Promotions",
  launches: "Launches", partnerships: "Partnerships",
  "security-compliance": "Security", "market-insights": "Markets",
  "tech-dev": "Tech", community: "Community", "use-cases": "Use Cases"
};

const catList = [...new Set(posts.filter(p => p.category).map(p => p.category))].sort();
const activeCat = Astro.url.searchParams.get("category");
const filtered = activeCat ? posts.filter(p => p.category === activeCat) : posts;
---

<style>
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    color: #fff;
    min-height: 80vh;
  }
  .blog-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    font-family: 'Urbanist', sans-serif;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }
  .blog-header p {
    color: #a0aec0;
    font-size: 0.95rem;
    font-family: 'Libre Franklin', sans-serif;
    margin-bottom: 32px;
  }
  
  .blog-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 32px;
  }

  .categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    border-bottom: 1px solid rgba(100, 51, 144, 0.2);
    padding-bottom: 24px;
  }
  
  .cat-btn {
    background: rgba(100, 51, 144, 0.15);
    border: 1px solid rgba(100, 51, 144, 0.25);
    color: #b388ff;
    padding: 8px 22px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Urbanist', sans-serif;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .cat-btn:hover {
    background: rgba(100, 51, 144, 0.25);
    border-color: rgba(100, 51, 144, 0.4);
    color: #fff;
  }
  .cat-btn.active {
    background: #643390;
    border-color: #643390;
    color: #fff;
    box-shadow: 0 4px 12px rgba(100, 51, 144, 0.3);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    align-content: start;
  }

  .post-card {
    background: rgba(100, 51, 144, 0.08);
    border: 1px solid rgba(100, 51, 144, 0.25);
    border-radius: 16px;
    padding: 24px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(4px);
  }
  .post-card:hover {
    border-color: rgba(100, 51, 144, 0.8);
    background: rgba(100, 51, 144, 0.15);
    transform: translateY(-2px);
  }
  
  .card-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .post-tag {
    background: rgba(100, 51, 144, 0.15);
    color: #b388ff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid rgba(100, 51, 144, 0.2);
    font-family: 'Libre Franklin', sans-serif;
  }
  .post-brand {
    color: #4a5568;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.4;
    color: #ffffff;
    font-family: 'Urbanist', sans-serif;
    margin-bottom: 10px;
    transition: color 0.2s;
  }
  .post-card:hover .post-title {
    color: #b388ff;
  }
  .post-desc {
    color: #a0aec0;
    font-size: 0.85rem;
    line-height: 1.6;
    font-family: 'Libre Franklin', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .post-date {
    color: #4a5568;
    font-size: 0.75rem;
    font-family: 'Libre Franklin', sans-serif;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .sidebar-box {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(100, 51, 144, 0.2);
    border-radius: 16px;
    padding: 24px;
    backdrop-filter: blur(4px);
    height: fit-content;
  }
  .sidebar-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sidebar-dot {
    width: 6px;
    height: 6px;
    background: #643390;
    border-radius: 55px;
    box-shadow: 0 0 8px #643390;
  }
  .sidebar-subtitle {
    color: #4a5568;
    font-size: 0.75rem;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding-bottom: 12px;
  }
  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sidebar-item {
    text-decoration: none;
    display: block;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .sidebar-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .sidebar-item-tag {
    font-size: 0.65rem;
    font-weight: 700;
    color: #b388ff;
    text-transform: uppercase;
  }
  .sidebar-item-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #cbd5e0;
    margin-top: 4px;
    line-height: 1.4;
    transition: color 0.2s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sidebar-item:hover .sidebar-item-title {
    color: #ffffff;
  }

  @media (max-width: 1024px) {
    .blog-layout { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
    .blog-header h1 { font-size: 2rem; }
  }
</style>

<Layout title="VETRA Blog">
  <div class="relative">
    <GenericHeader />
    <main>
      <div class="blog-container">
        <div class="blog-header">
          <h1>Blog</h1>
          <p>VETRA News, educational, content, and updates</p>
        </div>
        
        <div class="categories">
          <a href="/blog" class="cat-btn {!activeCat ? 'active' : ''}">All</a>
          {catList.map((cat) => (
            <a href={`/blog?category=${cat}`} class="cat-btn {activeCat === cat ? 'active' : ''}">{catNames[cat] || cat}</a>
          ))}
        </div>
        
        <div class="blog-layout">
          <div class="posts-grid">
            {filtered.length > 0 ? filtered.map((p) => {
              const date = new Date(p.created_at).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
              const label = catNames[p.category] || p.category;
              return (
                <a href={`/blog/${p.slug}`} class="post-card">
                  <div>
                    <div class="card-top">
                      <span class="post-tag">{label}</span>
                      <span class="post-brand">VETRA</span>
                    </div>
                    <h2 class="post-title">{p.title}</h2>
                    <p class="post-desc">{p.description}</p>
                  </div>
                  <div class="post-date">{date}</div>
                </a>
              );
            }) : (
              <p style="color: #4a5568; text-align: center; padding: 40px 0; grid-column: span 2;">No posts in this category</p>
            )}
          </div>
          
          <aside class="sidebar-box">
            <div class="sidebar-title">
              <span class="sidebar-dot"></span> Latest Updates
            </div>
            <div class="sidebar-subtitle">Most recent breakdowns from our team</div>
            <div class="sidebar-list">
              {posts.slice(0, 4).map((p) => {
                const label = catNames[p.category] || p.category;
                return (
                  <a href={`/blog/${p.slug}`} class="sidebar-item">
                    <span class="sidebar-item-tag">{label}</span>
                    <h4 class="sidebar-item-title">{p.title}</h4>
                  </a>
                );
              })}
            </div>
          </aside>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // placeholder para futura funcionalidade
});
</script>
